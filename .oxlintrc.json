{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "ignorePatterns": ["dist"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "fix": {
          "imports": "safe-fix",
          "variables": "off"
        }
      }
    ]
  },
  "env": {
    "builtin": true
  }
}
